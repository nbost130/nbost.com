---
const navLinks = [
  { href: '/', label: 'Home' },
  { href: '/ai', label: 'AI' },
  { href: '/prayer', label: 'Prayer' },
  { href: '/financial-planning', label: 'Financial Planning' },
];

const { pathname } = Astro.url;
---

<nav class="bg-brand-navy text-brand-cream shadow-md">
  <div class="max-w-5xl mx-auto px-4 sm:px-6">
    <div class="flex items-center justify-between h-16">
      <!-- Logo / Name -->
      <a href="/" class="text-brand-gold font-semibold text-lg tracking-wide hover:text-brand-gold-light transition-colors">
        Nathan Bost
      </a>

      <!-- Desktop links -->
      <ul class="hidden sm:flex items-center gap-6 text-sm font-medium">
        {navLinks.map(({ href, label }) => {
          const isActive = pathname === href || (href !== '/' && pathname.startsWith(href));
          return (
            <li>
              <a
                href={href}
                class={`transition-colors hover:text-brand-gold-light pb-0.5 border-b-2 ${
                  isActive
                    ? 'text-brand-gold border-brand-gold'
                    : 'text-brand-cream/80 border-transparent hover:border-brand-gold/50'
                }`}
              >
                {label}
              </a>
            </li>
          );
        })}
      </ul>

      <!-- Mobile menu button -->
      <button
        id="mobile-menu-btn"
        class="sm:hidden text-brand-cream/80 hover:text-brand-gold transition-colors"
        aria-label="Toggle menu"
        aria-expanded="false"
      >
        <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path id="icon-open" stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16" />
          <path id="icon-close" class="hidden" stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" />
        </svg>
      </button>
    </div>

    <!-- Mobile menu -->
    <div
      id="mobile-menu"
      class="sm:hidden overflow-hidden max-h-0 transition-[max-height] duration-300 ease-in-out"
      aria-hidden="true"
    >
      <ul class="flex flex-col gap-2 text-sm font-medium pb-4">
        {navLinks.map(({ href, label }) => {
          const isActive = pathname === href || (href !== '/' && pathname.startsWith(href));
          return (
            <li>
              <a
                href={href}
                class={`block py-2 px-3 rounded transition-colors ${
                  isActive
                    ? 'bg-brand-slate text-brand-gold'
                    : 'text-brand-cream/80 hover:bg-brand-slate/60 hover:text-brand-gold-light'
                }`}
              >
                {label}
              </a>
            </li>
          );
        })}
      </ul>
    </div>
  </div>
</nav>

<script>
  const btn = document.getElementById('mobile-menu-btn') as HTMLButtonElement | null;
  const menu = document.getElementById('mobile-menu') as HTMLElement | null;
  const iconOpen = document.getElementById('icon-open');
  const iconClose = document.getElementById('icon-close');

  btn?.addEventListener('click', () => {
    const isOpen = menu?.getAttribute('aria-hidden') === 'false';

    if (isOpen) {
      // Close
      if (menu) menu.style.maxHeight = '0';
      menu?.setAttribute('aria-hidden', 'true');
      iconOpen?.classList.remove('hidden');
      iconClose?.classList.add('hidden');
      btn.setAttribute('aria-expanded', 'false');
    } else {
      // Open — set max-height to scrollHeight for smooth animation
      if (menu) menu.style.maxHeight = menu.scrollHeight + 'px';
      menu?.setAttribute('aria-hidden', 'false');
      iconOpen?.classList.add('hidden');
      iconClose?.classList.remove('hidden');
      btn.setAttribute('aria-expanded', 'true');
    }
  });
</script>
