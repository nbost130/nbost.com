---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Home" description="Nathan Bost — Financial Advisor, AI consultant, and follower of Christ.">
  <div class="max-w-5xl mx-auto px-4 sm:px-6 py-16">
    <section class="text-center mb-16">
      <h1 class="text-4xl sm:text-5xl font-bold text-brand-navy mb-4">Nathan Bost</h1>
      <p class="text-brand-muted text-lg max-w-xl mx-auto">
        Financial Advisor. AI consultant. Follower of Christ. Based in Durham, NC.
      </p>
    </section>

    <section class="grid sm:grid-cols-3 gap-6">
      <a href="/ai" class="group block bg-white rounded-xl shadow-sm border border-brand-surface hover:shadow-md hover:border-brand-gold/40 transition-all p-6">
        <h2 class="text-xl font-semibold text-brand-navy group-hover:text-brand-gold transition-colors mb-2">AI Consulting</h2>
        <p class="text-brand-muted text-sm">Helping individuals and organizations harness AI tools thoughtfully and effectively.</p>
      </a>

      <a href="/prayer" class="group block bg-white rounded-xl shadow-sm border border-brand-surface hover:shadow-md hover:border-brand-gold/40 transition-all p-6">
        <h2 class="text-xl font-semibold text-brand-navy group-hover:text-brand-gold transition-colors mb-2">Prayer</h2>
        <p class="text-brand-muted text-sm">A place for reflection, Scripture, and the practices that anchor my life.</p>
      </a>

      <a href="/financial-planning" class="group block bg-white rounded-xl shadow-sm border border-brand-surface hover:shadow-md hover:border-brand-gold/40 transition-all p-6">
        <h2 class="text-xl font-semibold text-brand-navy group-hover:text-brand-gold transition-colors mb-2">Financial Planning</h2>
        <p class="text-brand-muted text-sm">Thoughtful guidance for long-term financial health, through Edward Jones.</p>
      </a>
    </section>
  </div>
</Layout>
